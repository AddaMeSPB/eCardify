default_platform(:ios)

# ---------- Constants ----------
XCODE_PROJECT = "eCardify.xcodeproj"
IOS_SCHEME    = "eCardify"
BUNDLE_ID     = "cardify.addame.com.eCardify"
TEAM_ID       = "6989658CU5"

# ---------- Helper Methods ----------

def api_key
  if ENV["APP_STORE_CONNECT_API_KEY_ID"]
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )
  elsif File.exist?("../fastlane/api_key.json")
    json = JSON.parse(File.read("../fastlane/api_key.json"))
    app_store_connect_api_key(
      key_id: json["key_id"],
      issuer_id: json["issuer_id"],
      key_content: json["key"],
      in_house: false
    )
  else
    UI.user_error!("No App Store Connect API key configured. Set APP_STORE_CONNECT_API_KEY_ID env var or create fastlane/api_key.json")
  end
end

platform :ios do

  desc "Sync code signing certificates and profiles"
  lane :certs do
    match(type: "appstore", api_key: api_key)
  end

  desc "Force regenerate provisioning profile (e.g. after adding capabilities)"
  lane :regen_profile do
    match(type: "appstore", force_for_new_devices: true, api_key: api_key)
  end

  desc "Generate App Store screenshots (swift-snapshot-testing)"
  lane :screenshots do
    sh("cd .. && chmod +x scripts/generate_screenshots.sh && ./scripts/generate_screenshots.sh --all")
    UI.success("Screenshots generated in fastlane/screenshots/")
  end

  desc "Upload screenshots only to App Store Connect"
  lane :upload_screenshots do
    key = api_key
    deliver(
      api_key: key,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      screenshots_path: "./fastlane/screenshots",
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    key = api_key
    match(type: "appstore", readonly: true, api_key: key)
    build_app(
      project: XCODE_PROJECT,
      scheme: IOS_SCHEME,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          BUNDLE_ID => "match AppStore #{BUNDLE_ID}"
        },
        signingCertificate: "Apple Distribution",
        teamID: TEAM_ID
      },
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID}",
      clean: true
    )
    upload_to_testflight(api_key: key, skip_waiting_for_build_processing: true)
  end

  desc "Upload metadata only to App Store Connect"
  lane :metadata do
    key = api_key
    deliver(
      api_key: key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      edit_live: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Upload screenshots to all Custom Product Pages defined in fastlane/cpp_pages.json"
  lane :upload_cpp_screenshots do |options|
    key_json = JSON.parse(File.read("../fastlane/api_key.json"))
    tmp_key = "/tmp/asc_cpp_upload_key.p8"
    File.write(tmp_key, key_json["key"])

    locale = options[:locale] || "en-GB"
    cpp_id_flag = options[:cpp_id] ? "--cpp-id #{options[:cpp_id]}" : ""
    screenshots_dir = options[:screenshots_dir] || "screenshots"

    sh(
      "python3 upload_cpp_screenshots.py " \
      "--key-id #{key_json['key_id']} " \
      "--issuer-id #{key_json['issuer_id']} " \
      "--private-key-file #{tmp_key} " \
      "--config cpp_pages.json " \
      "--screenshots-dir #{screenshots_dir} " \
      "--locale #{locale} " \
      "#{cpp_id_flag}"
    )
  ensure
    FileUtils.rm_f("/tmp/asc_cpp_upload_key.p8")
  end

end
